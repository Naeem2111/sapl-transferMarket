# Postgres (e.g. Neon). Get a free DB at https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Public URL for the new SAPL platform. Used by the archived homepage redirect.
NEXT_PUBLIC_NEW_SAPL_URL="https://sapl-platform.vercel.app"

# Optional: Twilio for sending OTP SMS. If not set, OTP is logged to console (dev mode).
# Get these from https://console.twilio.com - never commit real values.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
